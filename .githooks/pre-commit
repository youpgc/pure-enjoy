#!/bin/sh

# 检查是否在 CI 环境或没有 flutter 命令时跳过
if [ -n "$CI" ] || ! command -v flutter >/dev/null 2>&1; then
    echo "⚠️  跳过 Flutter 提交前验证（CI 环境或未安装 Flutter）"
    exit 0
fi

echo "🔍 正在运行 Flutter 提交前构建验证..."

# 获取依赖
echo "📦 获取 Flutter 依赖..."
flutter pub get
if [ $? -ne 0 ]; then
    echo "❌ 依赖获取失败，请检查 pubspec.yaml"
    exit 1
fi

# 运行 Flutter 静态分析
echo "📊 运行 Flutter 静态分析..."
flutter analyze
if [ $? -ne 0 ]; then
    echo "❌ Flutter 静态分析发现错误，请修复后再提交"
    exit 1
fi

# 运行本地 APK 构建（发现 analyze 通过仍可能构建失败）
echo "🏗️  运行本地 APK 构建验证..."
flutter build apk --release \
  --dart-define=SUPABASE_ANON_KEY=sb_publishable_wFx9tlxImVfEpRN4NMkS1g_QOm64aj6 \
  --dart-define=SUPABASE_URL=https://mhdrbjpqmzswswoazwjg.supabase.co
if [ $? -ne 0 ]; then
    echo "❌ APK 构建失败，请修复后再提交（使用 --no-verify 跳过）"
    exit 1
fi

echo "✅ Flutter 提交前验证通过（分析 + 构建）"
